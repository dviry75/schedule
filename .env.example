# Application
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/scheduler

# Auth
JWT_SECRET=replace_me_super_secret
JWT_EXPIRES_IN=1d

# Worker
WORKER_POLL_INTERVAL_MS=5000
WORKER_BATCH_SIZE=200
WORKER_MAX_CONCURRENCY=100
WORKER_MAX_PER_MINUTE=1000
SCHEDULE_EXPIRY_MINUTES=10
SCHEDULE_MAX_RETRIES=3
RETRY_DELAY_MINUTES=1
REQUEST_TIMEOUT_MS=3000
REAPER_INTERVAL_MS=60000
REAPER_STALE_LOCK_MINUTES=2
