    "start:worker": "node dist/workers/worker.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.1.0",
    "@fastify/jwt": "^9.1.0",
    "@fastify/sensible": "^5.6.0",
    "@prisma/client": "^6.5.0",
    "bcryptjs": "^2.4.3",
    "fastify": "^5.2.1",
    "p-limit": "^6.2.0",
    "pino": "^9.6.0",
    "undici": "^7.6.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.13.10",
    "prisma": "^6.5.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
