{
  "name": "saas-scheduling-engine",
  "version": "1.0.0",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:worker": "tsx watch src/workers/worker.ts",
    "build": "tsc -p tsconfig.json",
